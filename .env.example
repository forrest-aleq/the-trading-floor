# IBKR Gateway
IBKR_HOST=127.0.0.1
IBKR_PORT=4002
IBKR_CLIENT_ID=1
IBKR_CLIENT_ID_TRIES=5

# LLM
OPENROUTER_API_KEY=
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL_SPEED=openai/gpt-oss-120b
LLM_MODEL_ANALYSIS=qwen/qwen3.5-397b-a17b
LLM_MODEL_CRITICAL=qwen/qwen3.5-397b-a17b
LLM_MAX_CONCURRENCY=2
LLM_SPEED_MAX_CONCURRENCY=
LLM_ANALYSIS_MAX_CONCURRENCY=
LLM_CRITICAL_MAX_CONCURRENCY=
LLM_SPEED_PROVIDER_ORDER=groq
LLM_SPEED_PROVIDER_ALLOW_FALLBACKS=true
LLM_SPEED_PROVIDER_REQUIRE_PARAMETERS=true
LLM_ANALYSIS_PROVIDER_ORDER=Chutes,DeepInfra,Parasail,Together,Nebius,AtlasCloud
LLM_ANALYSIS_PROVIDER_ALLOW_FALLBACKS=true
LLM_ANALYSIS_PROVIDER_REQUIRE_PARAMETERS=true
LLM_REASONING_ENABLED=true
LLM_REASONING_EFFORT=low
LLM_REASONING_MAX_TOKENS=
LLM_JSON_REASONING_EFFORT=low
SCANNER_MODEL=openai/gpt-oss-120b
SCANNER_FALLBACK_MODELS=qwen/qwen3-235b-a22b-2507,qwen/qwen3.6-35b-a3b,deepseek/deepseek-v4-flash
RESEARCH_MODEL=qwen/qwen3.5-397b-a17b
COUNCIL_MODEL=qwen/qwen3.5-397b-a17b
PROSECUTION_MODEL=qwen/qwen3.5-397b-a17b
RESEARCH_RETRY_MODEL=
SCANNER_RESPONSE_MODE=thought
RESEARCH_RESPONSE_MODE=thought
PROSECUTION_RESPONSE_MODE=thought
COUNCIL_RESPONSE_MODE=thought
STRUCTURED_COMPILER_MODEL=openai/gpt-oss-120b
SCANNER_COMPILER_MODEL=openai/gpt-oss-120b
RESEARCH_COMPILER_MODEL=openai/gpt-oss-120b

# PostgreSQL
DATABASE_URL=postgres://localhost:5432/tradingfloor?sslmode=disable

# Optional Neo4j graph brain
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=

# Runtime controls
# dev is permissive for local coding. Use paper for unattended local runtime.
FLOOR_RUNTIME_MODE=dev
# Optional: connect/reconcile IBKR in the background even when no selected desk requires broker execution.
FLOOR_ENABLE_IBKR_RUNTIME=false
# Optional comma-separated desk allowlist for conservative unattended runs.
FLOOR_ENABLED_DESKS=
# Set true to add the opt-in prediction-market desk `pred-markets-a`.
FLOOR_ENABLE_PREDICTION_MARKET_DESK=false
# Set true to add the broader opt-in Kalshi desk pack.
FLOOR_ENABLE_KALSHI_DESKS=false
# Optional positive integer cap applied after FLOOR_ENABLED_DESKS.
FLOOR_DESK_LIMIT=
RISK_LIMITS_FILE=
# Leave blank to auto-detect. The runtime prefers Polygon/Massive when a key is
# present, then falls back to FMP.
MARKET_DATA_PROVIDER=
LOG_LEVEL=info
RISK_TOKEN_SECRET=change-me-to-a-secret-with-at-least-32-chars
MARKET_DATA_POLL_INTERVAL=30s
RUNTIME_HEARTBEAT_INTERVAL=30s
BELIEF_DECAY_INTERVAL=24h
BELIEF_DECAY_PCT=1.0
FLOOR_WORKERS=2
FLOOR_TASK_QUEUE_SIZE=2048
FLOOR_TASK_ENQUEUE_TIMEOUT=250ms
FLOOR_SLOW_TASK_WARN_AT=45s
DESK_SCANNER_TIMEOUT=35s
DESK_RESEARCH_TIMEOUT=75s
DESK_PROSECUTION_TIMEOUT=60s
DESK_COUNCIL_TIMEOUT=75s
DESK_EXECUTION_TIMEOUT=30s

# Kalshi real-money execution. Orders are blocked unless KALSHI_LIVE_TRADING=true
# and KALSHI_LIVE_CONFIRM=REAL_KALSHI_MONEY.
KALSHI_BASE_URL=https://external-api.kalshi.com/trade-api/v2
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=
KALSHI_PRIVATE_KEY_PEM=
KALSHI_LIVE_TRADING=false
KALSHI_LIVE_CONFIRM=
KALSHI_EXECUTION_MODE=dry_run
KALSHI_DRY_RUN_JOURNAL=kalshi_dry_run.jsonl
KALSHI_LIVE_KILL_SWITCH=false
KALSHI_LIVE_KILL_SWITCH_FILE=kalshi_live.kill
KALSHI_LIVE_MAX_ORDERS_PER_SESSION=1
KALSHI_LIVE_MAX_RISK_DOLLARS_PER_SESSION=1.00
KALSHI_LIVE_DISABLE_AFTER_FIRST=true
KALSHI_LIVE_DUPLICATE_COOLDOWN=15m
KALSHI_LIVE_ALLOWED_DESKS=kalshi-macro-a
KALSHI_LIVE_ALLOWED_TICKERS=
KALSHI_ACCOUNT_EQUITY_DOLLARS=
KALSHI_DESK_CAPITAL_DOLLARS=
KALSHI_MAX_ORDER_DOLLARS=1.00
KALSHI_MIN_ORDER_DOLLARS=0.00
KALSHI_RISK_PCT_EQUITY=2.0
KALSHI_MIN_CONVICTION=0.70
KALSHI_FEED_ENABLED=false
KALSHI_FEED_MARKET_LIMIT=12
KALSHI_FEED_INTERVAL=2m
DESK_SLOW_STAGE_WARN_AT=15s
DESK_ENABLE_SUBTEAMS=true
WIRE_NEWS_MAX_ITEMS_PER_SOURCE=5
WIRE_NEWS_MAX_ITEM_AGE=6h
WIRE_NEWS_EXTRA_SOURCES_JSON=
WIRE_SOCIAL_MAX_STOCKTWITS_ITEMS=4
WIRE_SOCIAL_MAX_REDDIT_ITEMS=3
WIRE_TRANSLATOR=passthrough
WIRE_TRANSLATION_TARGET_LANG=EN
DEEPL_API_KEY=
DEEPL_API_BASE_URL=https://api-free.deepl.com/v2/translate
DEEPL_MODEL_TYPE=latency_optimized
SCANNER_REQUEST_TIMEOUT=15s
SCANNER_MAX_TOKENS=128
SCANNER_COMPACT_MAX_TOKENS=96
SCANNER_THINKING_REQUEST_TIMEOUT=45s
SCANNER_THINKING_MAX_TOKENS=900
SCANNER_THINKING_COMPACT_MAX_TOKENS=700
SCANNER_COMPILER_TIMEOUT=25s
SCANNER_COMPILER_MAX_TOKENS=128
SCANNER_ERROR_CACHE_TTL=30s
RESEARCH_MAX_TOKENS=1024
RESEARCH_REQUEST_TIMEOUT=18s
STRUCTURED_THOUGHT_TIMEOUT=45s
RESEARCH_THOUGHT_TIMEOUT=60s
RESEARCH_RETRY_TIMEOUT=20s
RESEARCH_RETRY_MAX_TOKENS=384
RESEARCH_COMPILER_TIMEOUT=35s
RESEARCH_COMPILER_MAX_TOKENS=900
RESEARCH_DEFAULT_POSITION_SIZE_PCT=0.01
RESEARCH_STALE_DERIVATIVE_POLICY=underlying
EXECUTION_SUBMIT_RESULT_GRACE=1500ms
PROSECUTION_MAX_TOKENS=768
PROSECUTION_COMPILER_TIMEOUT=25s
PROSECUTION_COMPILER_MAX_TOKENS=900
COUNCIL_MAX_TOKENS=384
COUNCIL_TIMEOUT=25s
COUNCIL_COMPILER_TIMEOUT=25s
COUNCIL_COMPILER_MAX_TOKENS=600

# Optional overrides
TRADING_FLOOR_MIGRATION_PATH=store/migrations
INSTITUTIONAL_ACTION_POLICY_PATH=
FIRM_COLLABORATION_POLICY_PATH=

# Financial Modeling Prep
FMP_API_KEY=
FMP_API_BASE_URL=

# Polygon / Massive market data
POLYGON_API_KEY=
POLYGON_API_BASE_URL=
MASSIVE_PLAN=basic_free
# Massive is Polygon. These aliases are also supported:
# MASSIVE_API_KEY=
# MASSIVE_API_BASE_URL=
# Legacy alias still supported by code:
# EARNINGS_API_KEY=
# Legacy market data provider env alias still supported by code:
# MARKET_STATE_PROVIDER=

# Optional override for market/reference baskets and regime instruments
MARKET_REFS_POLICY_FILE=
