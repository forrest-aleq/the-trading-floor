# IBKR Gateway
IBKR_HOST=127.0.0.1
IBKR_PORT=4002
IBKR_CLIENT_ID=1
IBKR_CLIENT_ID_TRIES=5

# LLM
OPENROUTER_API_KEY=
LLM_BASE_URL=http://127.0.0.1:1234/v1
LLM_MODEL_SPEED=qwen/qwen3.5-9b
LLM_MODEL_ANALYSIS=qwen/qwen3.5-35b-a3b
LLM_MODEL_CRITICAL=qwen/qwen3.5-35b-a3b
LLM_MAX_CONCURRENCY=2
SCANNER_MODEL=qwen/qwen3.5-9b
SCANNER_RESPONSE_MODE=json
RESEARCH_RESPONSE_MODE=thought
PROSECUTION_RESPONSE_MODE=thought
COUNCIL_RESPONSE_MODE=thought
STRUCTURED_COMPILER_MODEL=gemma-the-writer-mighty-sword-9b
SCANNER_COMPILER_MODEL=gemma-the-writer-mighty-sword-9b

# PostgreSQL
DATABASE_URL=postgres://localhost:5432/tradingfloor?sslmode=disable

# Optional Neo4j graph brain
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=

# Runtime controls
LOG_LEVEL=info
RISK_TOKEN_SECRET=change-me
RUNTIME_HEARTBEAT_INTERVAL=30s
BELIEF_DECAY_INTERVAL=24h
BELIEF_DECAY_PCT=1.0
FLOOR_WORKERS=2
FLOOR_TASK_QUEUE_SIZE=2048
FLOOR_TASK_ENQUEUE_TIMEOUT=250ms
FLOOR_SLOW_TASK_WARN_AT=45s
DESK_SCANNER_TIMEOUT=35s
DESK_RESEARCH_TIMEOUT=75s
DESK_PROSECUTION_TIMEOUT=60s
DESK_COUNCIL_TIMEOUT=75s
DESK_EXECUTION_TIMEOUT=30s
DESK_SLOW_STAGE_WARN_AT=15s
WIRE_NEWS_MAX_ITEMS_PER_SOURCE=5
WIRE_NEWS_MAX_ITEM_AGE=6h
WIRE_NEWS_EXTRA_SOURCES_JSON=
WIRE_SOCIAL_MAX_STOCKTWITS_ITEMS=4
WIRE_SOCIAL_MAX_REDDIT_ITEMS=3
WIRE_TRANSLATOR=passthrough
WIRE_TRANSLATION_TARGET_LANG=EN
DEEPL_API_KEY=
DEEPL_API_BASE_URL=https://api-free.deepl.com/v2/translate
DEEPL_MODEL_TYPE=latency_optimized
SCANNER_REQUEST_TIMEOUT=15s
SCANNER_MAX_TOKENS=128
SCANNER_COMPACT_MAX_TOKENS=96
SCANNER_THINKING_REQUEST_TIMEOUT=12s
SCANNER_THINKING_MAX_TOKENS=128
SCANNER_THINKING_COMPACT_MAX_TOKENS=96
SCANNER_COMPILER_TIMEOUT=8s
SCANNER_COMPILER_MAX_TOKENS=96

# Optional overrides
TRADING_FLOOR_MIGRATION_PATH=store/migrations
